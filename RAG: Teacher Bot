    {
      "cell_type": "markdown",
      "source": [
        "## 5. Build RAG Chain"
      ],
      "metadata": {
        "id": "9vCbipxTnMYl"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "os.environ[\"GROQ_API_KEY\"] = userdata.get(\"GROQ_API_KEY\")\n",
        "\n",
        "llm = ChatGroq(\n",
        "    model = \"llama-3.3-70b-versatile\",\n",
        "    temperature = 0.3\n",
        ")\n",
        "\n",
        "def format_context(docs):\n",
        "    return \"\\n\\n\".join(\n",
        "    doc.page_content for doc in docs)\n",
        "\n",
        "\n",
        "prompt = ChatPromptTemplate.from_template(\n",
        "    \"\"\"\n",
        "    You are an excellent teacher. MUST use the context. Also give references from context.\n",
        "    Explain simply.\n",
        "\n",
        "    Context: {context}\n",
        "    Question: {question}\n",
        "    Answer:\n",
        "    \"\"\"\n",
        ")\n",
        "\n",
        "parser = StrOutputParser()\n",
        "\n",
        "\n",
        "def get_chain():\n",
        "\n",
        "    db = create_db()\n",
        "    retriever = get_retriever(db)\n",
        "\n",
        "    chain = (\n",
        "        {\n",
        "            \"context\": retriever | RunnableLambda(format_context),\n",
        "            \"question\": RunnablePassthrough()\n",
        "        }\n",
        "\n",
        "        | prompt | llm | parser\n",
        "    )\n",
        "\n",
        "    return chain"
      ],
      "metadata": {
        "id": "XlugmF0zG4qA"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 6. Ask Questions"
      ],
      "metadata": {
        "id": "IXRKlmC1nPMg"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "ask = get_chain()\n",
        "\n",
        "print(\"Bot: What do you want to learn?\")\n",
        "user_question = input(f\"You: \")\n",
        "response = ask.invoke(user_question)\n",
        "if user_question == 'q':\n",
        "    print(\"Chat exit\")\n",
        "    quit()\n",
        "\n",
        "print(f\"Bot: {response} \\n\\n\")\n",
        "\n",
        "while(user_question != \"q\"):\n",
        "\n",
        "  user_question = input(\"You: \" )\n",
        "  if user_question == 'q':\n",
        "    print(\"Chat exit\")\n",
        "    break\n",
        "  response = ask.invoke(user_question)\n",
        "  print(f\"Bot: {response} \\n\\n[To Exist Chat Input q] \\n\\n\")"
