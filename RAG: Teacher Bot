      }
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "sVjYHiGpD00n"
      },
      "outputs": [],
      "source": [
        "uploaded = files.upload()\n",
        "pdf_path = list((uploaded.keys()))[0]\n",
        "\n",
        "def load_docs():\n",
        "    loader = PyPDFLoader(pdf_path)\n",
        "    return loader.load()"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 3. Load & Split Document"
      ],
      "metadata": {
        "id": "HS1wVVRumFoZ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def split_docs():\n",
        "\n",
        "    docs = load_docs()\n",
        "\n",
        "    splitter = RecursiveCharacterTextSplitter(\n",
        "        chunk_size = 500,\n",
        "        chunk_overlap = 50\n",
        "    )\n",
        "\n",
        "\n",
        "    return splitter.split_documents(docs)\n",
        "\n",
        "\n",
        "chunks = split_docs()\n",
        "print(f\"Title: {chunks[0].metadata[\"title\"]}\")\n",
        "print(f\"Total Pages: {chunks[0].metadata[\"total_pages\"]}\")\n",
        "\n",
        "print(f\"Chunks created: {len(chunks)}\\n\")\n",
        "print(f\"First chunk:\\n\\n{chunks[0].page_content[:500]}...\")"
      ],
